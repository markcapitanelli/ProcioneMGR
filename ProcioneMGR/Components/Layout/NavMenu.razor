@implements IDisposable
@using System.Security.Claims
@using System.Text.Json
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="">
            <span class="brand-logo">🦝</span>
            <span>ProcioneMGR</span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                @foreach (var section in NavModel.Sections)
                {
                    var items = section.Items.Where(i => IsVisible(i, context.User)).ToList();
                    if (items.Count == 0)
                    {
                        continue; // Nessuna voce visibile per il ruolo corrente: salta il blocco.
                    }

                    if (section.Collapsible)
                    {
                        var open = IsOpen(section.Key);
                        <button type="button"
                                class="nav-section-header collapsible"
                                aria-expanded="@open.ToString().ToLowerInvariant()"
                                @onclick="() => Toggle(section.Key)"
                                @onclick:stopPropagation="true">
                            <span class="section-dot" style="background-color:@section.Accent"></span>
                            <span class="section-title">@section.Title</span>
                            <i class="bi bi-chevron-down section-caret @(open ? "open" : "")"></i>
                        </button>
                        <div class="nav-section-body @(open ? "open" : "collapsed")">
                            @foreach (var item in items)
                            {
                                @RenderItem(item)
                            }
                        </div>
                    }
                    else
                    {
                        <div class="nav-section-header static">
                            <span class="section-dot" style="background-color:@section.Accent"></span>
                            <span class="section-title">@section.Title</span>
                        </div>
                        @foreach (var item in items)
                        {
                            @RenderItem(item)
                        }
                    }
                }

                <div class="nav-section-header static">
                    <span class="section-dot" style="background-color:#94a3b8"></span>
                    <span class="section-title">Account</span>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <i class="bi bi-person-fill"></i> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <i class="bi bi-box-arrow-left"></i> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <i class="bi bi-person-plus-fill"></i> Registrati
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private const string StorageKey = "procione.nav.sections";

    private string? currentUrl;
    private bool _stateLoaded;

    // Stato aperto/chiuso dei soli blocchi collassabili. Default: chiusi.
    private readonly Dictionary<string, bool> _open = new();

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);

        foreach (var key in NavModel.CollapsibleKeys)
        {
            _open[key] = false;
        }

        // Apre di default il blocco che contiene la pagina corrente (voce attiva sempre visibile).
        EnsureCurrentSectionOpen();

        NavigationManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // localStorage non è disponibile durante il prerender: si legge solo qui, dopo
        // il primo render interattivo, così da non bloccare la UI e non causare eccezioni.
        try
        {
            var raw = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrWhiteSpace(raw))
            {
                var saved = JsonSerializer.Deserialize<Dictionary<string, bool>>(raw);
                if (saved is not null)
                {
                    foreach (var (key, value) in saved)
                    {
                        if (_open.ContainsKey(key))
                        {
                            _open[key] = value;
                        }
                    }
                }
            }
        }
        catch
        {
            // localStorage assente/negato (es. privacy mode): si prosegue con i default.
        }

        // La sezione della pagina corrente resta comunque aperta, anche se in storage era chiusa.
        EnsureCurrentSectionOpen();
        _stateLoaded = true;
        StateHasChanged();
    }

    private bool IsOpen(string key) => _open.TryGetValue(key, out var v) && v;

    private async Task Toggle(string key)
    {
        if (!_open.ContainsKey(key))
        {
            return;
        }

        _open[key] = !_open[key];
        await PersistAsync();
    }

    private async Task PersistAsync()
    {
        try
        {
            var json = JsonSerializer.Serialize(_open);
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch
        {
            // Persistenza best-effort: un fallimento non deve rompere la navigazione.
        }
    }

    private void EnsureCurrentSectionOpen()
    {
        var key = NavModel.SectionKeyOf(currentUrl ?? string.Empty);
        if (key is not null && _open.ContainsKey(key))
        {
            _open[key] = true;
        }
    }

    private static bool IsVisible(NavItem item, ClaimsPrincipal user)
    {
        // Roles null = qualsiasi utente autenticato (equivale al vecchio AuthorizeView senza Roles).
        if (item.Roles is null)
        {
            return true;
        }

        foreach (var role in item.Roles)
        {
            if (user.IsInRole(role))
            {
                return true;
            }
        }
        return false;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);

        // Navigando in una voce di un blocco collassato, lo apre così la voce attiva è visibile.
        var key = NavModel.SectionKeyOf(currentUrl);
        if (_stateLoaded && key is not null && _open.TryGetValue(key, out var open) && !open)
        {
            _open[key] = true;
            _ = PersistAsync();
        }

        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    // Frammento riusabile per una singola voce di menu (attivo evidenziato via NavLink).
    private RenderFragment RenderItem(NavItem item) => __builder =>
    {
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@item.Href"
                     Match="@(item.Match ? NavLinkMatch.All : NavLinkMatch.Prefix)">
                <i class="bi @item.Icon"></i> @item.Label
            </NavLink>
        </div>
    };
}
