@page "/optimization"
@rendermode InteractiveServer
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using ProcioneMGR.Data
@using ProcioneMGR.Services.Backtesting
@using ProcioneMGR.Services.Exchanges
@using ProcioneMGR.Services.Indicators
@using ProcioneMGR.Services.Optimization
@attribute [Authorize(Roles = AppRoles.Admin + "," + AppRoles.Manager)]
@implements IAsyncDisposable

@inject IStrategyFactory StrategyFactory
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS
@inject OptimizationPageService Svc

<PageTitle>Optimization</PageTitle>

<h1>Parameter Optimization <span class="badge bg-secondary">Walk-Forward</span></h1>

<GuidaPanel Title="Optimization — trova i parametri migliori senza illudersi">
    <p>
        Ogni strategia ha dei "numeri regolabili" (es. quanto veloce/lenta una media mobile).
        Provare a mano decine di combinazioni è lento; questa pagina le prova <strong>tutte</strong>
        automaticamente (grid search) e sceglie le migliori. Il problema è che una strategia
        "ottimizzata" sui dati che hai già visto tende a sembrare migliore di quanto sarà davvero
        in futuro (si dice che è "overfittata" — ha imparato a memoria il passato, non una regola
        generale). Per questo la piattaforma usa il metodo <strong>walk-forward</strong>: divide
        lo storico in finestre consecutive, ottimizza su una finestra (<em>in-sample</em>, i dati
        "di allenamento") e verifica il risultato SOLO sulla finestra successiva, mai vista prima
        (<em>out-of-sample</em>, il vero test). Il numero che conta davvero è lo Sharpe
        <strong>out-of-sample</strong>, non quello in-sample.
    </p>
    <dl class="row mb-0">
        <dt class="col-sm-3">Symbol / Timeframe / Da-A</dt>
        <dd class="col-sm-9">Lo stesso significato del Backtest: la coppia, la granularità delle candele e il periodo storico complessivo su cui girare l'intera analisi walk-forward.</dd>
        <dt class="col-sm-3">Strategia</dt>
        <dd class="col-sm-9">
            La regola da ottimizzare. "Modello ML (salvato)" è un caso speciale: invece di una
            strategia a regole fisse, usa un modello di machine learning già addestrato in
            <a href="ml">ML Lab</a> — qui si ottimizzano solo le sue soglie di decisione, non il
            modello stesso.
        </dd>
        <dt class="col-sm-3">Range parametri (Grid Search)</dt>
        <dd class="col-sm-9">
            Per ogni parametro scegli un minimo, un massimo e un passo (step): la piattaforma
            proverà ogni combinazione possibile. Attenzione: più parametri e passi più piccoli =
            molte più combinazioni da testare (il numero è mostrato sotto la tabella) e tempi più
            lunghi.
        </dd>
        <dt class="col-sm-3">In-Sample / Out-of-Sample / Step (mesi)</dt>
        <dd class="col-sm-9">
            Quanto è larga la finestra di allenamento (In-Sample), quanto quella di verifica
            immediatamente successiva (Out-of-Sample), e di quanto si sposta in avanti la finestra
            a ogni passo (Step) — finestre che si sovrappongono (Step &lt; In-Sample) riusano parte
            dei dati, finestre non sovrapposte danno un test più severo ma richiedono più storico.
        </dd>
        <dt class="col-sm-3">Top 10</dt>
        <dd class="col-sm-9">Le 10 combinazioni di parametri con il miglior Sharpe out-of-sample medio sulle finestre — quella evidenziata in verde è la migliore in assoluto.</dd>
        <dt class="col-sm-3">Heatmap</dt>
        <dd class="col-sm-9">
            Visibile solo con esattamente 2 parametri: una mappa colorata che mostra dove si trova
            la "zona buona" — colori uniformi e continui indicano una strategia robusta, macchie
            isolate indicano un risultato fortunato/instabile su cui non fare troppo affidamento.
        </dd>
        <dt class="col-sm-3">Equity curve Walk-Forward</dt>
        <dd class="col-sm-9">Il capitale ottenuto incollando in sequenza SOLO i risultati out-of-sample di ogni finestra — la stima più onesta di come sarebbe andata "dal vivo".</dd>
        <dt class="col-sm-3">Finestre Walk-Forward</dt>
        <dd class="col-sm-9">Il dettaglio finestra per finestra: se lo Sharpe in-sample è molto più alto di quello out-of-sample, è un segnale di overfitting in quella finestra.</dd>
        <dt class="col-sm-3">Save Best Configuration</dt>
        <dd class="col-sm-9">Salva la combinazione migliore in <a href="strategies">Le mie strategie</a>, taggata come "ottimizzata".</dd>
    </dl>
</GuidaPanel>

<div class="card mb-3">
    <div class="card-header">Configurazione</div>
    <div class="card-body">
        <ConfigPresets @ref="_presets" PageKey="optimization" UserId="@_userId" Disabled="_busy"
                       Capture="CaptureConfigJson" Apply="ApplyConfigJson"
                       AutoRestoreLast="@(string.IsNullOrEmpty(QuerySymbol))" />
        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label">Exchange</label>
                <select class="form-select" @bind="_exchange" disabled="@_busy">
                    @foreach (var ex in Enum.GetValues<ExchangeName>())
                    { <option value="@ex">@ex</option> }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">Symbol</label>
                <input class="form-control" list="opt_symbols" @bind="_symbol" style="width: 10rem;" disabled="@_busy" />
                <datalist id="opt_symbols">
                    @foreach (var s in Svc.KnownSymbols) { <option value="@s"></option> }
                </datalist>
            </div>
            <div class="col-auto">
                <label class="form-label">Timeframe</label>
                <select class="form-select" @bind="_timeframe" disabled="@_busy">
                    @foreach (var tf in Timeframes.Supported.Keys) { <option value="@tf">@tf</option> }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">Da</label>
                <input type="date" class="form-control" @bind="_from" disabled="@_busy" />
            </div>
            <div class="col-auto">
                <label class="form-label">A</label>
                <input type="date" class="form-control" @bind="_to" disabled="@_busy" />
            </div>
        </div>

        <DataAvailability Symbol="@_symbol" Timeframe="@_timeframe" From="_from" To="_to" Disabled="_busy"
                          OnApplyRange="@(r => { _from = r.From; _to = r.To; })"
                          OnHasDataChanged="@(has => _hasData = has)" />

        <hr />
        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label">Strategia</label>
                <select class="form-select" value="@_strategyName" @onchange="OnStrategyChanged" disabled="@_busy">
                    @foreach (var p in StrategyFactory.Prototypes) { <option value="@p.Name">@p.DisplayName</option> }
                    <option value="@MlStrategyName">Modello ML (salvato)</option>
                </select>
            </div>
        </div>

        @if (_strategyName == MlStrategyName)
        {
            var compatibleMlModels = Svc.MlModels.Where(m => m.Symbol == _symbol.Trim() && m.Timeframe == _timeframe).ToList();
            <div class="row g-3 align-items-end mt-1">
                <div class="col-auto">
                    <label class="form-label">Modello ML (@_symbol @_timeframe)</label>
                    @if (compatibleMlModels.Count == 0)
                    {
                        <div class="form-text text-warning">Nessun modello salvato per questo symbol/timeframe (addestralo in /ml).</div>
                    }
                    else
                    {
                        <select class="form-select" @bind="_addMlModelId" disabled="@_busy">
                            <option value="0">—</option>
                            @foreach (var m in compatibleMlModels)
                            {
                                <option value="@m.Id">@m.Name (@m.ModelType)</option>
                            }
                        </select>
                    }
                </div>
            </div>
        }

        <hr />
        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label">Metodo di ricerca</label>
                <select class="form-select" @bind="_searchStrategy" disabled="@_busy">
                    <option value="@SearchStrategy.GridSearch">Grid Search (esaustivo)</option>
                    <option value="@SearchStrategy.Bayesian">Bayesian (guidato)</option>
                </select>
            </div>
            @if (_searchStrategy == SearchStrategy.Bayesian)
            {
                <div class="col-auto">
                    <label class="form-label">Iterazioni guidate</label>
                    <input type="number" class="form-control" style="width:8rem" @bind="_bayesIterations" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Punti iniziali</label>
                    <input type="number" class="form-control" style="width:8rem" @bind="_bayesInitialRandom" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Seme</label>
                    <input type="number" class="form-control" style="width:7rem" @bind="_bayesSeed" disabled="@_busy" />
                </div>
                <div class="col-auto align-self-center">
                    <span class="badge bg-info text-dark">Budget/finestra: @(_bayesInitialRandom + _bayesIterations) valutazioni</span>
                </div>
            }
        </div>
        @if (_searchStrategy == SearchStrategy.Bayesian)
        {
            <div class="form-text mt-1">
                La ricerca guidata (Gaussian Process + Expected Improvement) propone i punti da provare
                invece del prodotto cartesiano: i range sotto definiscono solo i confini e la granularità
                (step/intero) dello spazio. Lo Sharpe guida la ricerca; il Deflated Sharpe resta il verdetto
                finale su tutti i punti visitati. Deterministico a parità di seme.
            </div>
        }

        <div class="mt-3">
            <label class="form-label fw-semibold">Range parametri@(_searchStrategy == SearchStrategy.Bayesian ? " (confini dello spazio)" : " (Grid Search)")</label>
            <table class="table table-sm" style="max-width: 720px;">
                <thead><tr><th>Parametro</th><th>Min</th><th>Max</th><th>Step</th><th>Intero</th></tr></thead>
                <tbody>
                    @foreach (var r in _ranges)
                    {
                        <tr>
                            <td>@r.Label</td>
                            <td><input type="number" step="any" class="form-control form-control-sm" style="width:6rem" @bind="r.Min" disabled="@_busy" /></td>
                            <td><input type="number" step="any" class="form-control form-control-sm" style="width:6rem" @bind="r.Max" disabled="@_busy" /></td>
                            <td><input type="number" step="any" class="form-control form-control-sm" style="width:6rem" @bind="r.Step" disabled="@_busy" /></td>
                            <td><input type="checkbox" class="form-check-input" @bind="r.IsInteger" disabled="@_busy" /></td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="text-muted small">
                @if (_searchStrategy == SearchStrategy.Bayesian)
                {
                    <span>Valutazioni per finestra (budget): <strong>@(_bayesInitialRandom + _bayesIterations)</strong> — la ricerca guidata NON prova tutte le @TotalCombos() combinazioni.</span>
                }
                else
                {
                    <span>Combinazioni totali: <strong>@TotalCombos()</strong></span>
                }
            </div>
        </div>

        @* Capitale, commissione e finestre walk-forward hanno default sensati:
           fuori dalla vista finché non servono, riassunto sempre leggibile. *@
        <AdvancedPanel Summary="@AdvancedSummary">
            <div class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label">Capitale</label>
                    <input type="number" step="any" class="form-control" style="width: 8rem;" @bind="_initialCapital" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Commissione %</label>
                    <input type="number" step="any" class="form-control" style="width: 7rem;" @bind="_commission" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">In-Sample (mesi)</label>
                    <input type="number" class="form-control" style="width:7rem" @bind="_inSampleMonths" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Out-of-Sample (mesi)</label>
                    <input type="number" class="form-control" style="width:7rem" @bind="_oosMonths" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Step (mesi)</label>
                    <input type="number" class="form-control" style="width:7rem" @bind="_stepMonths" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Embargo (barre)</label>
                    <input type="number" min="0" class="form-control" style="width:7rem" @bind="_embargoBars" disabled="@_busy" />
                    <div class="form-text" style="max-width: 16rem;">
                        Barre saltate all'inizio di ogni out-of-sample: evita che posizioni aperte e
                        lookback degli indicatori filtrino informazione dall'in-sample. Valore sensato:
                        il lookback massimo della strategia (es. 200 per una SMA200). 0 = nessun embargo.
                    </div>
                </div>
            </div>
        </AdvancedPanel>

        <div class="mt-3 d-flex gap-2 align-items-center">
            <button class="btn btn-primary" @onclick="StartAsync" disabled="@(_busy || !_hasData)"
                    title="@(!_hasData ? $"Nessun dato per {_symbol} {_timeframe}: scaricali prima da Watchlist." : null)">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Start Optimization
            </button>
            @if (_busy)
            {
                <button class="btn btn-outline-danger" @onclick="Stop">Stop</button>
            }
        </div>

        @if (_busy)
        {
            <div class="progress mt-3" style="height: 22px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:@(Pct)%">
                    @_progress.Message — best Sharpe @_progress.BestSharpeSoFar.ToString("F2") (@Pct%)
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(_status))
        {
            <div class="alert @(_isError ? "alert-danger" : "alert-success") mt-3 mb-0">@_status</div>
        }
    </div>
</div>

@if (Svc.Result is { } result)
{
    @if (result.Validation is { } v)
    {
        <div class="alert @(v.IsSignificant ? "alert-success" : "alert-warning") d-flex justify-content-between align-items-center mb-3">
            <div>
                <strong>Deflated Sharpe: @((v.DeflatedSharpe * 100).ToString("F1"))%</strong>
                @(v.IsSignificant ? " — edge difendibile dopo correzione per test multiplo" : " — NON significativo: probabile artefatto della ricerca (selection bias)")
            </div>
            <span class="small text-muted">
                soglia attesa SR* (per-periodo): @v.ExpectedMaxSharpePerPeriod.ToString("F4") ·
                osservato: @v.ObservedSharpePerPeriod.ToString("F4") ·
                @v.Trials combinazioni · @v.Observations osservazioni
            </span>
        </div>
    }
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Top 10 — Sharpe OOS medio (selezione finestra su in-sample)</span>
            <span class="small text-muted">@result.TotalCombinationsTested valutazioni in @result.ExecutionTime.TotalSeconds.ToString("F1")s · Sharpe OOS medio finestre: <strong>@result.WalkForwardAnalysis.AverageOutOfSampleSharpe.ToString("F3")</strong></span>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead><tr><th>#</th><th>Parametri</th><th class="text-end">Sharpe IS</th><th class="text-end">Sharpe OOS</th><th class="text-end">Return %</th><th class="text-end">Max DD %</th><th class="text-end">Trades</th><th></th></tr></thead>
                <tbody>
                    @{ var rank = 0; }
                    @foreach (var s in result.BestParameters)
                    {
                        rank++;
                        <tr class="@(rank == 1 ? "table-success" : "")">
                            <td>@rank</td>
                            <td>@FormatParams(s.Parameters)</td>
                            <td class="text-end">@s.InSampleSharpe.ToString("F2")</td>
                            <td class="text-end fw-semibold">@s.OutOfSampleSharpe.ToString("F2")</td>
                            <td class="text-end @(s.TotalReturn >= 0 ? "text-success" : "text-danger")">@s.TotalReturn.ToString("F2")</td>
                            <td class="text-end text-danger">@s.MaxDrawdown.ToString("F2")</td>
                            <td class="text-end">@s.TotalTrades</td>
                            <td class="text-end">
                                @if (Svc.ResultConfig is { } rc && rc.StrategyName != MlStrategyName)
                                {
                                    <a class="btn btn-sm btn-outline-primary py-0" href="@Svc.BacktestHandoffUrl(s.Parameters)"
                                       title="Apri il Backtest precompilato con questi parametri">Backtest →</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer d-flex align-items-center gap-2 flex-wrap">
            <div class="input-group" style="max-width: 520px;">
                <input class="form-control" placeholder="nome configurazione" @bind="_saveName" />
                <button class="btn btn-success" @onclick="SaveBestAsync">💾 Save Best Configuration</button>
            </div>
            @if (_savedOk)
            {
                <a class="btn btn-outline-primary" href="ensemble"
                   title="Le configurazioni ottimizzate salvate sono selezionabili nell'Ensemble">Aggiungila all'Ensemble →</a>
            }
        </div>
    </div>

    @if (_ranges.Count == 2 && result.AllResults.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header">Heatmap robustezza (Sharpe OOS medio)</div>
            <div class="card-body"><div id="opt_heatmap" style="width:100%;"></div></div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-header">Equity curve Walk-Forward (out-of-sample concatenati)</div>
        <div class="card-body">
            @if (Svc.EquitySeries.Count > 0)
            {
                <OhlcvChart ShowCandles="false" Indicators="Svc.EquitySeries" Height="300" />
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">Finestre Walk-Forward</div>
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead><tr><th>#</th><th>In-Sample</th><th>Out-of-Sample</th><th>Best params</th><th class="text-end">Sharpe IS</th><th class="text-end">Sharpe OOS</th><th class="text-end">OOS Return %</th></tr></thead>
                <tbody>
                    @foreach (var win in result.WalkForwardAnalysis.Windows)
                    {
                        <tr>
                            <td>@win.WindowIndex</td>
                            <td>@win.InSampleStart.ToString("yyyy-MM") → @win.InSampleEnd.ToString("yyyy-MM")</td>
                            <td>@win.OutOfSampleStart.ToString("yyyy-MM") → @win.OutOfSampleEnd.ToString("yyyy-MM")</td>
                            <td>@FormatParams(win.BestParameters)</td>
                            <td class="text-end">@win.InSampleSharpe.ToString("F2")</td>
                            <td class="text-end">@win.OutOfSampleSharpe.ToString("F2")</td>
                            <td class="text-end @(win.OutOfSampleReturn >= 0 ? "text-success" : "text-danger")">@win.OutOfSampleReturn.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    // Contesto opzionale passato dal Backtest ("Ottimizza questa strategia →") o dal
    // ML Lab ("Ottimizza" su un modello salvato): precompila simbolo/periodo/strategia,
    // ricentra i range sui parametri del run e preseleziona il modello ML.
    [SupplyParameterFromQuery(Name = "exchange")] private string? QueryExchange { get; set; }
    [SupplyParameterFromQuery(Name = "symbol")] private string? QuerySymbol { get; set; }
    [SupplyParameterFromQuery(Name = "timeframe")] private string? QueryTimeframe { get; set; }
    [SupplyParameterFromQuery(Name = "strategy")] private string? QueryStrategy { get; set; }
    [SupplyParameterFromQuery(Name = "from")] private string? QueryFrom { get; set; }
    [SupplyParameterFromQuery(Name = "to")] private string? QueryTo { get; set; }
    [SupplyParameterFromQuery(Name = "parameters")] private string? QueryParameters { get; set; }
    [SupplyParameterFromQuery(Name = "model")] private int? QueryModelId { get; set; }

    private ExchangeName _exchange = ExchangeName.Binance;
    private string _symbol = "BTC/USDT";
    private string _timeframe = "1h";
    private DateTime _from = new(2024, 6, 1);
    private DateTime _to = new(2026, 6, 1);
    private decimal _initialCapital = 10_000m;
    private decimal _commission = 0.1m;
    private int _inSampleMonths = 12;
    private int _oosMonths = 3;
    private int _stepMonths = 3;
    private int _embargoBars;

    private SearchStrategy _searchStrategy = SearchStrategy.GridSearch;
    private int _bayesIterations = 40;
    private int _bayesInitialRandom = 8;
    private int _bayesSeed = 42;

    private const string MlStrategyName = OptimizationPageService.MlStrategyName;

    private string _strategyName = "EmaCross";
    private List<RangeInput> _ranges = new();
    private int _addMlModelId;

    private bool _savedOk;   // mostra il testimone "Aggiungila all'Ensemble →" dopo un salvataggio riuscito
    private string _saveName = "";
    private string? _userId;

    private bool _busy;
    private bool _isError;
    private string? _status;
    private OptimizationProgress _progress = new();
    private CancellationTokenSource? _cts;

    // Aggiornato dal componente DataAvailability (gating dello Start).
    private bool _hasData = true;

    private ConfigPresets? _presets;

    /// <summary>Fotografia corrente del form, passata al service per run/preset/handoff.</summary>
    private OptimizationConfigSnapshot Snapshot() => new(
        _exchange, _symbol, _timeframe, _from, _to,
        _initialCapital, _commission, _inSampleMonths, _oosMonths, _stepMonths,
        _searchStrategy, _bayesIterations, _bayesInitialRandom, _bayesSeed,
        _strategyName, _addMlModelId,
        _ranges.Select(r => new OptRange(r.Key, r.Label, r.Min, r.Max, r.Step, r.IsInteger)).ToList(),
        _embargoBars);

    /// <summary>Riallinea i campi del form a uno snapshot prodotto dal service (preset o handoff).</summary>
    private void ApplySnapshot(OptimizationConfigSnapshot cfg)
    {
        _exchange = cfg.Exchange;
        _symbol = cfg.Symbol;
        _timeframe = cfg.Timeframe;
        _from = cfg.From;
        _to = cfg.To;
        _initialCapital = cfg.InitialCapital;
        _commission = cfg.Commission;
        _inSampleMonths = cfg.InSampleMonths;
        _oosMonths = cfg.OosMonths;
        _stepMonths = cfg.StepMonths;
        _embargoBars = cfg.EmbargoBars;
        _searchStrategy = cfg.SearchStrategy;
        _bayesIterations = cfg.BayesIterations;
        _bayesInitialRandom = cfg.BayesInitialRandom;
        _bayesSeed = cfg.BayesSeed;
        _strategyName = cfg.StrategyName;
        _addMlModelId = cfg.MlModelId;
        _ranges = cfg.Ranges
            .Select(r => new RangeInput { Key = r.Key, Label = r.Label, Min = r.Min, Max = r.Max, Step = r.Step, IsInteger = r.IsInteger })
            .ToList();
    }

    private string CaptureConfigJson() => Svc.SerializeConfig(Snapshot());

    private void ApplyConfigJson(string json) => ApplySnapshot(Svc.ApplyConfig(json, Snapshot()));

    /// <summary>Riassunto delle impostazioni avanzate, visibile a pannello chiuso.</summary>
    private string AdvancedSummary =>
        $"Capitale {_initialCapital:N0} · Commissione {_commission:0.##}%"
        + $" · Walk-forward {_inSampleMonths}/{_oosMonths}/{_stepMonths} mesi (IS/OOS/Step)"
        + (_embargoBars > 0 ? $" · Embargo {_embargoBars} barre" : "");

    private IJSObjectReference? _heatmapModule;
    private bool _heatmapPending;

    private int Pct => _progress.TotalCombinations == 0 ? 0 : (int)Math.Min(100, (long)_progress.CombinationsTested * 100 / _progress.TotalCombinations);

    private sealed class RangeInput
    {
        public required string Key { get; init; }
        public required string Label { get; init; }
        public decimal Min { get; set; }
        public decimal Max { get; set; }
        public decimal Step { get; set; }
        public bool IsInteger { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier);

        // Eventuale contesto dal Backtest / ML Lab (query string): valori assenti o malformati
        // lasciano i default; i range partono dai default della strategia e vengono ricentrati
        // sui parametri del run di provenienza.
        var (snapshot, handoffMessage) = Svc.ApplyHandoff(
            new OptimizationHandoffQuery(QueryExchange, QuerySymbol, QueryTimeframe, QueryStrategy, QueryFrom, QueryTo, QueryParameters, QueryModelId),
            Snapshot());
        ApplySnapshot(snapshot);
        if (handoffMessage is not null) SetStatus(handoffMessage, error: false);

        await Svc.LoadInitialDataAsync();
    }

    private void OnStrategyChanged(ChangeEventArgs e)
    {
        _strategyName = e.Value?.ToString() ?? "EmaCross";
        _ranges = Svc.DefaultRangesFor(_strategyName)
            .Select(r => new RangeInput { Key = r.Key, Label = r.Label, Min = r.Min, Max = r.Max, Step = r.Step, IsInteger = r.IsInteger })
            .ToList();
    }

    private int TotalCombos() => OptimizationPageService.TotalCombinations(
        _ranges.Select(r => new OptRange(r.Key, r.Label, r.Min, r.Max, r.Step, r.IsInteger)).ToList());

    private async Task StartAsync()
    {
        // Memoria dell'ultima configurazione usata (best-effort, mai bloccante).
        if (_presets is not null) await _presets.SaveLastUsedAsync();

        _busy = true; _isError = false; _status = null; _savedOk = false;
        _progress = new(); _cts = new CancellationTokenSource();
        try
        {
            var progress = new Progress<OptimizationProgress>(p => { _progress = p; InvokeAsync(StateHasChanged); });
            var res = await Svc.RunAsync(Snapshot(), _userId, progress, _cts.Token);
            SetStatus(res.Message, res.IsError);
            _heatmapPending = !res.IsError && _ranges.Count == 2 && Svc.Result is { AllResults.Count: > 0 };
        }
        catch (OperationCanceledException) { SetStatus("Ottimizzazione annullata.", true); }
        catch (Exception ex) { SetStatus($"Errore: {ex.Message}", true); }
        finally { _busy = false; _cts?.Dispose(); _cts = null; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_heatmapPending && Svc.Result is not null)
        {
            _heatmapPending = false;
            await RenderHeatmapAsync();
        }
    }

    private async Task RenderHeatmapAsync()
    {
        if (_ranges.Count != 2) return;
        var matrix = Svc.BuildHeatmapMatrix(_ranges[0].Key, _ranges[1].Key);
        if (matrix is null) return;

        _heatmapModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/heatmap.js");
        await _heatmapModule.InvokeVoidAsync("renderHeatmap", "opt_heatmap",
            matrix.Xs, matrix.Ys, matrix.Z, _ranges[0].Key, _ranges[1].Key);
    }

    private void Stop() => _cts?.Cancel();

    private async Task SaveBestAsync()
    {
        if (_userId is null) return;
        var res = await Svc.SaveBestAsync(_saveName, _strategyName, _userId);
        if (res is null) return;   // nessun run/risultato: silenzioso, come prima
        SetStatus(res.Message, res.IsError);
        if (!res.IsError)
        {
            _saveName = "";
            _savedOk = true; // prossimo passo del flusso: l'Ensemble la vede tra le configurazioni ottimizzate
        }
    }

    private static string FormatParams(Dictionary<string, decimal> p) =>
        string.Join(", ", p.Select(kv => $"{kv.Key}={kv.Value}"));

    private void SetStatus(string text, bool error) { _status = text; _isError = error; }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_heatmapModule is not null)
            {
                await _heatmapModule.InvokeVoidAsync("dispose", "opt_heatmap");
                await _heatmapModule.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { }
    }
}
