@page "/ml"
@rendermode InteractiveServer
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.ML
@using ProcioneMGR.Data
@using ProcioneMGR.Services.Alpha
@using ProcioneMGR.Services.AlphaMining
@using ProcioneMGR.Services.Backtesting
@using ProcioneMGR.Services.Exchanges
@using ProcioneMGR.Services.Indicators
@using ProcioneMGR.Services.ML
@using ProcioneMGR.Services.Optimization
@using ProcioneMGR.Services.Experiments
@attribute [Authorize(Roles = AppRoles.Admin + "," + AppRoles.Manager)]

@inject IAlphaFactorFactory FactorFactory
@inject AuthenticationStateProvider AuthProvider
@inject MlLabService Svc

<PageTitle>ML Lab</PageTitle>

<h1>ML Lab</h1>

<GuidaPanel Title="ML Lab — insegnare a un modello a prevedere il prezzo, onestamente">
    <p>
        Invece di scrivere regole fisse (es. "compra quando la media veloce supera quella lenta"),
        qui si addestra un modello di <strong>machine learning</strong> a prevedere il rendimento
        futuro a partire da alcuni indicatori numerici (i "fattori alpha": momentum, volatilità,
        RSI, ecc.). Il punto cruciale è la <strong>disciplina anti-imbroglio</strong>: il modello
        si allena SOLO sul periodo "Train" e viene poi testato SOLO sul periodo "Test" successivo,
        che non ha mai visto — esattamente come si dovrebbe valutare qualunque previsione, altrimenti
        sembrerebbe "geniale" solo perché ha memorizzato il passato invece di aver imparato uno
        schema utile.
    </p>
    <dl class="row mb-0">
        <dt class="col-sm-3">% Train</dt>
        <dd class="col-sm-9">Che percentuale del periodo selezionato usare per l'allenamento (es. 70% train, 30% test) — il test avviene sempre sulla parte più recente, mai vista.</dd>
        <dt class="col-sm-3">Orizzonte forward</dt>
        <dd class="col-sm-9">Quante candele nel futuro il modello prova a prevedere (es. 1 = il rendimento della prossima candela).</dd>
        <dt class="col-sm-3">Modello</dt>
        <dd class="col-sm-9">
            Il tipo di algoritmo: <strong>Lineare</strong> (semplice, veloce, spiegabile),
            <strong>Random Forest</strong> e <strong>Gradient Boosting</strong> (più complessi,
            possono catturare relazioni non lineari ma richiedono più dati per non "imparare a
            memoria" il rumore).
        </dd>
        <dt class="col-sm-3">Fattori alpha</dt>
        <dd class="col-sm-9">Gli indicatori numerici che il modello userà come indizi per la previsione — più ne selezioni, più informazione ha a disposizione, ma anche più rischio di rumore se sono ridondanti tra loro.</dd>
        <dt class="col-sm-3">Correlazione in-sample</dt>
        <dd class="col-sm-9">Quanto bene il modello si adatta ai dati di allenamento — un numero alto qui NON garantisce che funzionerà fuori campione, è solo un primo controllo.</dd>
        <dt class="col-sm-3">Feature importance</dt>
        <dd class="col-sm-9">Quanto peggiora la qualità delle previsioni se si "confonde" un singolo fattore — i fattori con importanza più alta sono quelli su cui il modello si affida di più.</dd>
        <dt class="col-sm-3">Soglia Long / Short</dt>
        <dd class="col-sm-9">Il rendimento previsto minimo, in positivo o negativo, oltre il quale il modello apre effettivamente una posizione (sotto soglia resta fuori dal mercato).</dd>
        <dt class="col-sm-3">Esegui backtest (out-of-sample)</dt>
        <dd class="col-sm-9">Il vero momento della verità: simula le operazioni SOLO sul periodo "Test" mai visto in addestramento — è questo risultato, non la correlazione in-sample, quello a cui prestare attenzione.</dd>
        <dt class="col-sm-3">Salva modello</dt>
        <dd class="col-sm-9">Salva il modello addestrato per riusarlo in <a href="optimization">Optimization</a> o <a href="ensemble">Ensemble</a> senza doverlo riaddestrare ogni volta.</dd>
    </dl>
</GuidaPanel>

<div class="card mb-3">
    <div class="card-header">1. Dati e fattori</div>
    <div class="card-body">
        <ConfigPresets @ref="_presets" PageKey="ml" UserId="@_userId" Disabled="_busy"
                       Capture="CaptureConfigJson" Apply="ApplyConfigJson" />
        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label">Exchange</label>
                <select class="form-select" @bind="_exchange" disabled="@_busy">
                    @foreach (var ex in Enum.GetValues<ExchangeName>())
                    {
                        <option value="@ex">@ex</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">Symbol</label>
                <input class="form-control" list="ml_symbols" @bind="_symbol" style="width: 11rem;" disabled="@_busy" />
                <datalist id="ml_symbols">
                    @foreach (var s in Svc.KnownSymbols)
                    {
                        <option value="@s"></option>
                    }
                </datalist>
            </div>
            <div class="col-auto">
                <label class="form-label">Timeframe</label>
                <select class="form-select" @bind="_timeframe" disabled="@_busy">
                    @foreach (var tf in Timeframes.Supported.Keys)
                    {
                        <option value="@tf">@tf</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">Da</label>
                <input type="date" class="form-control" @bind="_from" disabled="@_busy" />
            </div>
            <div class="col-auto">
                <label class="form-label">A</label>
                <input type="date" class="form-control" @bind="_to" disabled="@_busy" />
            </div>
            <div class="col-auto">
                <label class="form-label">Modello</label>
                <select class="form-select" @bind="_modelType" disabled="@_busy">
                    <option value="Linear">Lineare (SDCA)</option>
                    <option value="RandomForest">Random Forest</option>
                    <option value="GradientBoosting">Gradient Boosting (LightGBM)</option>
                    <option value="Mlp">Rete neurale (MLP, C# puro)</option>
                    <option value="Stacked">Stacking (ensemble di modelli)</option>
                    <option value="Attention">Attention / Transformer (C# puro)</option>
                </select>
            </div>
        </div>

        <DataAvailability Symbol="@_symbol" Timeframe="@_timeframe" From="_from" To="_to" Disabled="_busy"
                          OnApplyRange="@(r => { _from = r.From; _to = r.To; })"
                          OnHasDataChanged="@(has => _hasData = has)" />

        @if (_modelType == "Stacked")
        {
            <div class="border rounded p-2 mt-2 bg-light">
                <label class="form-label d-block mb-1">Modelli base dello stacking</label>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var bt in ReturnPredictorCatalog.BaseTypes)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="@("sb_" + bt)"
                                   checked="@_stackBaseModels.Contains(bt)"
                                   @onchange="e => ToggleStackBase(bt, e.Value is true)" disabled="@_busy" />
                            <label class="form-check-label" for="@("sb_" + bt)">@bt</label>
                        </div>
                    }
                    <div class="col-auto ms-3">
                        <label class="form-label mb-0 me-1">Combinazione</label>
                        <select class="form-select form-select-sm d-inline-block" style="width: auto;" @bind="_stackMode" disabled="@_busy">
                            <option value="Average">Media semplice</option>
                            <option value="InverseRmse">Peso ∝ 1/RMSE</option>
                            <option value="StackedRidge">Meta-learner ridge (OOF)</option>
                        </select>
                    </div>
                </div>
                <p class="small text-muted mb-0 mt-1">
                    Lo stacking combina le predizioni di più modelli. «Meta-learner ridge» usa predizioni
                    out-of-fold (purged CV) per pesarli senza leakage.
                </p>
            </div>
        }

        @if (_modelType == "Attention")
        {
            <div class="border rounded p-2 mt-2 bg-light">
                <div class="d-flex flex-wrap align-items-end gap-3">
                    <div>
                        <label class="form-label mb-0">Finestra (timestep)</label>
                        <input type="number" min="2" max="60" class="form-control form-control-sm" style="width: 8rem;" @bind="_attnWindow" disabled="@_busy" />
                    </div>
                    <div>
                        <label class="form-label mb-0">Dim. embedding</label>
                        <input type="number" min="4" max="64" class="form-control form-control-sm" style="width: 8rem;" @bind="_attnEmbed" disabled="@_busy" />
                    </div>
                    <p class="small text-muted mb-0">
                        Self-attention su una finestra di T candele (i fattori come input), in C# puro
                        (niente TorchSharp): il modello impara quali istanti passati contano di più.
                    </p>
                </div>
            </div>
        }

        <hr />

        <label class="form-label d-block">Fattori alpha (feature del modello)</label>
        <div class="d-flex flex-wrap gap-3">
            @foreach (var proto in FactorFactory.Prototypes)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="@("f_" + proto.Name)"
                           checked="@_selectedFactors.Contains(proto.Name)"
                           @onchange="e => ToggleFactor(proto.Name, e.Value is true)" disabled="@_busy" />
                    <label class="form-check-label" for="@("f_" + proto.Name)">@proto.DisplayName</label>
                </div>
            }
        </div>

        @if (Svc.SavedFactors.Count > 0)
        {
            <label class="form-label d-block mt-3">Fattori minati (Alpha Mining)</label>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var sf in Svc.SavedFactors)
                {
                    <div class="form-check" title="@sf.Expression">
                        <input class="form-check-input" type="checkbox" id="@("sf_" + sf.Id)"
                               checked="@_selectedSavedFactorIds.Contains(sf.Id)"
                               @onchange="e => ToggleSavedFactor(sf.Id, e.Value is true)" disabled="@_busy" />
                        <label class="form-check-label" for="@("sf_" + sf.Id)">
                            @sf.Name <span class="text-muted small">(@sf.Symbol @sf.Timeframe)</span>
                        </label>
                    </div>
                }
            </div>
        }

        <AdvancedPanel Summary="@AdvancedSummary">
            <div class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label">% Train</label>
                    <input type="number" step="1" min="10" max="90" class="form-control" style="width: 7rem;" @bind="_trainSplitPercent" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Orizzonte forward</label>
                    <input type="number" step="1" min="1" class="form-control" style="width: 8rem;" @bind="_forwardHorizon" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Target</label>
                    <select class="form-select" style="width: 14rem;" @bind="_targetKind" disabled="@_busy">
                        <option value="@MlTargetKind.ForwardReturn">Rendimento (default)</option>
                        <option value="@MlTargetKind.ForwardAbsReturn">|Rendimento| (rischio)</option>
                        <option value="@MlTargetKind.ForwardRealizedVol">Volatilità realizzata</option>
                    </select>
                    <div class="form-text" style="max-width: 20rem;">
                        Dopo 445.280 combinazioni direzionali a zero sopravvissuti, predire il <em>rischio</em> è la
                        domanda con più probabilità di risposta. I modelli non-rendimento si salvano col loro
                        <strong>TargetKind</strong> e non possono mai alimentare segnali long/short né diventare
                        Champion: il consumo è la valutazione QLIKE/MSE contro l'EWMA (e, se la battono, il vol-targeting).
                    </div>
                </div>
            </div>
        </AdvancedPanel>

        <div class="mt-3">
            <button class="btn btn-primary" @onclick="TrainAsync"
                    disabled="@(_busy || !_hasData || (_selectedFactors.Count == 0 && _selectedSavedFactorIds.Count == 0))"
                    title="@(!_hasData ? $"Nessun dato per {_symbol} {_timeframe}: scaricali prima da Watchlist." : null)">
                @if (_busy && _stage == Stage.Training)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                2. Addestra
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_status))
        {
            <div class="alert @(_isError ? "alert-danger" : "alert-success") mt-3 mb-0">@_status</div>
        }
    </div>
</div>

@if (Svc.SavedModels.Count > 0)
{
    <div class="card mb-3">
        <div class="card-header">Modelli salvati</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th><th>Tipo</th><th>Symbol</th><th>Timeframe</th>
                        <th>Periodo train</th><th class="text-end">Righe</th><th class="text-end">Corr. in-sample</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Svc.SavedModels)
                    {
                        <tr>
                            <td>@m.Name</td>
                            <td>@m.ModelType</td>
                            <td>@m.Symbol</td>
                            <td>@m.Timeframe</td>
                            <td>@m.TrainingDataFrom.ToString("yyyy-MM-dd") → @m.TrainingDataTo.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">@m.TrainRowCount</td>
                            <td class="text-end">@m.TrainCorrelation.ToString("F3")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-success @(_busy ? "disabled" : "")" href="@MlLabService.OptimizationHandoffUrl(m)"
                                   title="Ottimizza le soglie Long/Short di questo modello in walk-forward, sui dati successivi al training">Ottimizza →</a>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => LoadSavedModelAsync(m.Id)" disabled="@_busy">Carica</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSavedModelAsync(m.Id)" disabled="@_busy">Elimina</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Svc.HasTrainedModel)
{
    <div class="card mb-3">
        <div class="card-header">Modello addestrato</div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-auto">@MetricCard("Righe train", $"{Svc.TrainRowCount}")</div>
                <div class="col-auto">@MetricCard("Correlazione in-sample", $"{Svc.TrainCorrelation:F3}")</div>
                <div class="col-auto">@MetricCard("Candele test (OOS)", $"{Svc.TestCandles?.Count ?? 0}")</div>
            </div>

            @if (Svc.FeatureImportance.Count > 0)
            {
                <div class="mb-3">
                    <label class="form-label d-block">Feature importance (permutation, in-sample)</label>
                    <table class="table table-sm" style="max-width: 30rem;">
                        <thead><tr><th>Fattore</th><th class="text-end">Calo R² se permutato</th></tr></thead>
                        <tbody>
                            @foreach (var fi in Svc.FeatureImportance)
                            {
                                <tr>
                                    <td>@fi.FeatureName</td>
                                    <td class="text-end">@fi.MeanDecreaseInRSquared.ToString("F4")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label">Soglia Long</label>
                    <input type="number" step="any" class="form-control" style="width: 9rem;" @bind="_longThreshold" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Soglia Short</label>
                    <input type="number" step="any" class="form-control" style="width: 9rem;" @bind="_shortThreshold" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Capitale iniziale</label>
                    <input type="number" step="any" class="form-control" style="width: 9rem;" @bind="_initialCapital" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Position size %</label>
                    <input type="number" step="any" class="form-control" style="width: 8rem;" @bind="_positionSizePercent" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Fee %</label>
                    <input type="number" step="any" class="form-control" style="width: 7rem;" @bind="_feePercent" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    @if (Svc.SessionTargetKind == MlTargetKind.ForwardReturn)
                    {
                        <button class="btn btn-success" @onclick="BacktestAsync" disabled="@_busy">
                            @if (_busy && _stage == Stage.Backtesting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            3. Esegui backtest (out-of-sample)
                        </button>
                    }
                    else if (Svc.SessionTargetKind == MlTargetKind.ForwardRealizedVol)
                    {
                        @* [1.V fase 2] Il consumo di un modello di RISCHIO non è un backtest direzionale
                           ma il confronto con la baseline: batte l'EWMA out-of-sample sì o no? *@
                        <button class="btn btn-success" @onclick="EvaluateVolAsync" disabled="@_busy">
                            @if (_busy && _stage == Stage.Backtesting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            3. Valuta previsione di vol (QLIKE/MSE vs EWMA)
                        </button>
                    }
                    else
                    {
                        <span class="form-text">Il target |rendimento| si misura in addestramento (correlazione); per il confronto con l'EWMA usa "Volatilità realizzata".</span>
                    }
                </div>
            </div>

            <hr />

            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label">Nome modello da salvare</label>
                    <input class="form-control" style="width: 18rem;" placeholder="es. RF momentum BTC 1h" @bind="_saveModelName" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <button class="btn btn-outline-secondary" @onclick="SaveModelAsync" disabled="@_busy">Salva modello</button>
                </div>
            </div>
        </div>
    </div>
}

@if (Svc.VolEvaluation is { } vol)
{
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Previsione di volatilità — modello vs baseline (out-of-sample, @vol.Rows barre)</span>
            <span class="badge @(vol.ModelBeatsEwma ? "bg-success" : "bg-warning text-dark")">
                @(vol.ModelBeatsEwma ? "batte l'EWMA" : "NON batte l'EWMA")
            </span>
        </div>
        <div class="card-body">
            <table class="table table-sm mb-2" style="max-width: 560px;">
                <thead><tr><th></th><th class="text-end">QLIKE (↓ meglio)</th><th class="text-end">MSE vol (↓ meglio)</th></tr></thead>
                <tbody>
                    <tr class="@(vol.ModelBeatsEwma ? "table-success" : "")">
                        <td>Modello ML</td>
                        <td class="text-end">@vol.ModelQlike.ToString("F4")</td>
                        <td class="text-end">@vol.ModelMse.ToString("E2")</td>
                    </tr>
                    <tr>
                        <td>EWMA (λ=0,94)</td>
                        <td class="text-end">@vol.EwmaQlike.ToString("F4")</td>
                        <td class="text-end">@vol.EwmaMse.ToString("E2")</td>
                    </tr>
                    <tr>
                        <td>Naive (vol passata)</td>
                        <td class="text-end">@vol.NaiveQlike.ToString("F4")</td>
                        <td class="text-end">@vol.NaiveMse.ToString("E2")</td>
                    </tr>
                </tbody>
            </table>
            <div class="form-text">
                QLIKE è la loss standard per le previsioni di varianza (penalizza le sottostime, l'errore
                costoso per il risk management). Verdetto onesto: finché il modello non batte l'EWMA qui,
                il vol-targeting della piattaforma continua a usare la volatilità realizzata semplice.
            </div>
        </div>
    </div>
}

@if (Svc.Result is { } result)
{
    <div class="row g-3 mb-3">
        @{
            var positive = result.TotalReturnPercent >= 0;
        }
        <div class="col-auto">@MetricCard("Final Capital", $"{result.FinalCapital:N2}")</div>
        <div class="col-auto">@MetricCard("Total Return", $"{result.TotalReturnPercent:N2}%", positive)</div>
        <div class="col-auto">@MetricCard("Win Rate", $"{result.WinRate:N1}%")</div>
        <div class="col-auto">@MetricCard("Max Drawdown", $"{result.MaxDrawdownPercent:N2}%", false)</div>
        <div class="col-auto">@MetricCard("Trades", $"{result.TotalTrades} ({result.WinningTrades}W/{result.LosingTrades}L)")</div>
    </div>

    @if (Svc.Tearsheet is { } tearsheet)
    {
        <div class="row g-3 mb-3">
            <div class="col-auto">@MetricCard("Sharpe", $"{tearsheet.Sharpe:F2}")</div>
            <div class="col-auto">@MetricCard("Sortino", $"{tearsheet.Sortino:F2}")</div>
            <div class="col-auto">@MetricCard("Calmar", $"{tearsheet.Calmar:F2}")</div>
            <div class="col-auto">@MetricCard("Omega", $"{tearsheet.Omega:F2}")</div>
            <div class="col-auto">@MetricCard("VaR 95%", $"{tearsheet.ValueAtRisk95:P2}")</div>
            <div class="col-auto">@MetricCard("CVaR 95%", $"{tearsheet.ConditionalValueAtRisk95:P2}")</div>
            <div class="col-auto">@MetricCard("Max DD durata", $"{tearsheet.MaxDrawdownDurationPeriods} periodi")</div>
            <div class="col-auto">@MetricCard("Esposizione", $"{tearsheet.ExposurePercent:F1}%")</div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-header">Equity curve (out-of-sample)</div>
        <div class="card-body">
            @if (Svc.EquitySeries.Count > 0)
            {
                <OhlcvChart ShowCandles="false" Indicators="Svc.EquitySeries" Height="320" />
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">Trade list (@result.Trades.Count)</div>
        <div class="table-responsive" style="max-height: 460px; overflow:auto;">
            <table class="table table-sm table-striped mb-0">
                <thead class="table-light" style="position: sticky; top: 0;">
                    <tr>
                        <th>#</th><th>Dir</th><th>Entry</th><th>Exit</th>
                        <th class="text-end">Entry px</th><th class="text-end">Exit px</th>
                        <th class="text-end">PnL</th><th class="text-end">PnL %</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var idx = 0;
                    }
                    @foreach (var t in result.Trades.Take(500))
                    {
                        idx++;
                        <tr>
                            <td>@idx</td>
                            <td><span class="badge @(t.Direction == "Long" ? "bg-success" : "bg-danger")">@t.Direction</span></td>
                            <td>@t.EntryTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(t.ExitTime?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                            <td class="text-end">@t.EntryPrice.ToString("N2")</td>
                            <td class="text-end">@(t.ExitPrice?.ToString("N2") ?? "—")</td>
                            <td class="text-end @(t.Pnl >= 0 ? "text-success" : "text-danger")">@t.Pnl.ToString("N2")</td>
                            <td class="text-end @(t.PnlPercent >= 0 ? "text-success" : "text-danger")">@t.PnlPercent.ToString("N2")%</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (result.Trades.Count > 500)
        {
            <div class="card-footer text-muted">Mostrati i primi 500 di @result.Trades.Count trade.</div>
        }
    </div>
}

@code {
    private enum Stage { Idle, Training, Backtesting }

    private ExchangeName _exchange = ExchangeName.Binance;
    private string _symbol = "BTC/USDT";
    private string _timeframe = "1h";
    private DateTime _from = DateTime.UtcNow.Date.AddDays(-120);
    private DateTime _to = DateTime.UtcNow.Date;
    private int _trainSplitPercent = 70;
    private int _forwardHorizon = 1;
    private MlTargetKind _targetKind = MlTargetKind.ForwardReturn;

    private readonly HashSet<string> _selectedFactors = new() { "Momentum", "RsiFactor", "MacdFactor" };

    private decimal _longThreshold = 0.005m;
    private decimal _shortThreshold = 0.005m;
    private decimal _initialCapital = 10_000m;
    private decimal _positionSizePercent = 20m;
    private decimal _feePercent = 0.1m;

    private string _modelType = "Linear";
    private readonly HashSet<string> _stackBaseModels = new() { "Linear", "RandomForest" };
    private StackingMode _stackMode = StackingMode.StackedRidge;
    private int _attnWindow = 8;
    private int _attnEmbed = 16;

    private Stage _stage = Stage.Idle;
    private bool _busy;

    // Aggiornato dal componente DataAvailability (gating dell'addestramento).
    private bool _hasData = true;

    /// <summary>Riassunto delle impostazioni avanzate, visibile a pannello chiuso.</summary>
    private string AdvancedSummary =>
        $"Train {_trainSplitPercent}% · Orizzonte forward {_forwardHorizon} candel{(_forwardHorizon == 1 ? "a" : "e")}";
    private bool _isError;
    private string? _status;

    private string? _userId;
    private string _saveModelName = "";
    private readonly HashSet<int> _selectedSavedFactorIds = new();

    private ConfigPresets? _presets;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
        await Svc.LoadInitialDataAsync(_userId);
    }

    /// <summary>Fotografia corrente del form, passata al service per train/backtest/save/preset.</summary>
    private MlConfigSnapshot Snapshot() => new(
        _exchange, _symbol, _timeframe, _from, _to, _trainSplitPercent, _forwardHorizon,
        _selectedFactors.ToList(), _selectedSavedFactorIds.ToList(),
        _modelType, _stackBaseModels.ToList(), _stackMode, _attnWindow, _attnEmbed,
        _longThreshold, _shortThreshold, _initialCapital, _positionSizePercent, _feePercent,
        _targetKind);

    private string CaptureConfigJson() => Svc.SerializeConfig(Snapshot());

    private void ApplyConfigJson(string json)
    {
        var cfg = Svc.ApplyConfig(json, Snapshot());
        _exchange = cfg.Exchange;
        _symbol = cfg.Symbol;
        _timeframe = cfg.Timeframe;
        _from = cfg.From;
        _to = cfg.To;
        _trainSplitPercent = cfg.TrainSplitPercent;
        _forwardHorizon = cfg.ForwardHorizon;
        _selectedFactors.Clear();
        foreach (var f in cfg.Factors) _selectedFactors.Add(f);
        _selectedSavedFactorIds.Clear();
        foreach (var id in cfg.SavedFactorIds) _selectedSavedFactorIds.Add(id);
        _modelType = cfg.ModelType;
        _stackBaseModels.Clear();
        foreach (var m in cfg.StackBaseModels) _stackBaseModels.Add(m);
        _stackMode = cfg.StackMode;
        _attnWindow = cfg.AttnWindow;
        _attnEmbed = cfg.AttnEmbed;
        _longThreshold = cfg.LongThreshold;
        _shortThreshold = cfg.ShortThreshold;
        _initialCapital = cfg.InitialCapital;
        _positionSizePercent = cfg.PositionSizePercent;
        _feePercent = cfg.FeePercent;
    }

    private void ToggleFactor(string name, bool selected)
    {
        if (selected) _selectedFactors.Add(name);
        else _selectedFactors.Remove(name);
    }

    private void ToggleSavedFactor(int id, bool selected)
    {
        if (selected) _selectedSavedFactorIds.Add(id);
        else _selectedSavedFactorIds.Remove(id);
    }

    private void ToggleStackBase(string name, bool selected)
    {
        if (selected) _stackBaseModels.Add(name);
        else _stackBaseModels.Remove(name);
    }

    private async Task TrainAsync()
    {
        if (string.IsNullOrWhiteSpace(_symbol) || _to <= _from)
        {
            SetStatus("Controlla symbol e intervallo date.", error: true);
            return;
        }

        // Memoria dell'ultima configurazione usata (best-effort, mai bloccante).
        if (_presets is not null) await _presets.SaveLastUsedAsync();

        _busy = true;
        _stage = Stage.Training;
        SetStatus(null, error: false);
        try
        {
            var res = await Svc.TrainAsync(Snapshot(), _userId);
            SetStatus(res.Message, res.IsError);
        }
        catch (Exception ex)
        {
            SetStatus($"Errore in addestramento: {ex.Message}", error: true);
        }
        finally
        {
            _busy = false;
            _stage = Stage.Idle;
        }
    }

    private async Task BacktestAsync()
    {
        _busy = true;
        _stage = Stage.Backtesting;
        _isError = false;
        try
        {
            var res = await Svc.BacktestAsync(Snapshot());
            SetStatus(res.Message, res.IsError);
        }
        catch (Exception ex)
        {
            SetStatus($"Errore nel backtest: {ex.Message}", error: true);
        }
        finally
        {
            _busy = false;
            _stage = Stage.Idle;
        }
    }

    /// <summary>[1.V fase 2] Valuta la previsione di vol del modello in sessione contro EWMA/naive.</summary>
    private async Task EvaluateVolAsync()
    {
        _busy = true;
        _stage = Stage.Backtesting;
        _isError = false;
        try
        {
            var res = await Svc.EvaluateVolForecastAsync();
            SetStatus(res.Message, res.IsError);
        }
        catch (Exception ex)
        {
            SetStatus($"Errore nella valutazione: {ex.Message}", error: true);
        }
        finally
        {
            _busy = false;
            _stage = Stage.Idle;
        }
    }

    private async Task SaveModelAsync()
    {
        _busy = true;
        try
        {
            var res = await Svc.SaveModelAsync(Snapshot(), _saveModelName, _userId);
            if (!res.IsError) _saveModelName = "";
            SetStatus(res.Message, res.IsError);
        }
        catch (Exception ex)
        {
            SetStatus($"Errore nel salvataggio: {ex.Message}", error: true);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task LoadSavedModelAsync(int id)
    {
        _busy = true;
        _isError = false;
        try
        {
            var res = await Svc.LoadSavedModelAsync(id, _from, _to, _userId);
            if (res.Symbol is not null) _symbol = res.Symbol;
            if (res.Timeframe is not null) _timeframe = res.Timeframe;
            if (res.ModelType is not null) _modelType = res.ModelType;
            _targetKind = res.TargetKind;   // [1.V fase 2] la semantica viaggia col modello
            SetStatus(res.Message, res.IsError);
        }
        catch (Exception ex)
        {
            SetStatus($"Errore nel caricamento: {ex.Message}", error: true);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteSavedModelAsync(int id) => await Svc.DeleteSavedModelAsync(id, _userId);

    private void SetStatus(string? text, bool error)
    {
        _status = text;
        _isError = error;
    }

    // Delega al componente condiviso <Stat> (stile unico in app.css). Le call-site
    // (@MetricCard(...)) restano invariate: qui cambia solo la resa.
    private RenderFragment MetricCard(string label, string value, bool? positive = null) => builder =>
    {
        builder.OpenComponent<Stat>(0);
        builder.AddComponentParameter(1, nameof(Stat.Label), label);
        builder.AddComponentParameter(2, nameof(Stat.Value), value);
        builder.AddComponentParameter(3, nameof(Stat.Positive), positive);
        builder.CloseComponent();
    };
}
