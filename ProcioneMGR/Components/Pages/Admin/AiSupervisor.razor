@page "/admin/ai-supervisor"
@rendermode InteractiveServer
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using ProcioneMGR.Data
@using ProcioneMGR.Services.Llm
@using ProcioneMGR.Services.Pipeline
@attribute [Authorize(Roles = $"{AppRoles.Admin},{AppRoles.Manager}")]

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ILlmClient LlmClient
@inject ILlmCallGuard Guard
@inject IPipelineSupervisor Supervisor
@inject LlmSupervisorWorker LlmWorker

<PageTitle>Supervisione AI</PageTitle>

<h1>Supervisione AI del ciclo di ricerca</h1>

<GuidaPanel Title="Supervisione AI — un consulente sulle cacce, non un esecutore">
    <p>
        A ogni run del pipeline concluso, un agente AR (Claude) legge la <code>PipelineRecommendation</code>
        prodotta dal motore e scrive un <strong>parere leggibile</strong>: un riepilogo, eventuali
        aggiustamenti proposti ai parametri di caccia, e le decisioni che richiedono la tua
        <strong>conferma esplicita</strong>.
    </p>
    <p class="mb-0">
        <strong>Confine di sicurezza (non negoziabile):</strong> l'AI è <em>solo advisory</em>. Non può
        avviare il trading live, non può bypassare i controlli di sicurezza (<code>SafetyChecker</code>),
        non apre posizioni. I suoi suggerimenti sui parametri sono spunti da valutare, mai comandi
        applicati in automatico. Il layer è attivo solo se <code>Llm:Enabled=true</code> e la variabile
        d'ambiente <code>ANTHROPIC_API_KEY</code> è impostata.
    </p>
</GuidaPanel>

@* ---- Stato del layer (chiave, breaker, backlog) + azioni di recupero ---- *@
<div class="card mb-3">
    <div class="card-header"><i class="bi bi-heart-pulse me-1"></i>Stato del layer AI</div>
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
            @if (LlmClient.IsConfigured)
            { <span class="badge bg-success">ANTHROPIC_API_KEY presente</span> }
            else
            { <span class="badge bg-danger">ANTHROPIC_API_KEY assente</span> }

            @if (_guard is { BreakerOpen: true })
            {
                <span class="badge bg-danger">
                    SOSPESO — @(_guard.LastFailureCause ?? "errori ripetuti")@(_guard.NextProbeUtc is not null ? $", riprovo alle {_guard.NextProbeUtc.Value.ToLocalTime():HH:mm}" : "")
                </span>
            }
            else
            {
                <span class="badge bg-success">operativo</span>
            }

            <span class="badge bg-light text-dark">advisory ok: @_okCount</span>
            <span class="badge @(_errorCount > 0 ? "bg-warning text-dark" : "bg-light text-dark")">in errore: @_errorCount</span>
            <span class="badge @(_pendingRuns > 0 ? "text-bg-info" : "bg-light text-dark")">run in attesa (7 gg): @_pendingRuns</span>
        </div>
        <p class="text-muted small mb-2">
            @if (_guard is { BreakerOpen: true })
            {
                <span>Ultimo errore: <em>@_guard.LastFailureMessage</em>. Il ripristino è automatico (probe periodico);
                "Riprova adesso" forza un tentativo subito — utile appena risolta la causa (es. credito API ricaricato).</span>
            }
            else
            {
                <span>Ultimo tentativo: @FormatTs(_guard?.LastAttemptUtc) · ultimo successo: @FormatTs(_guard?.LastSuccessUtc).</span>
            }
        </p>
        @if (!string.IsNullOrEmpty(_actionStatus))
        {
            <div class="alert @(_actionIsError ? "alert-danger" : "alert-success") py-2">@_actionStatus</div>
        }
        <button class="btn btn-outline-secondary me-2" @onclick="LoadAsync" disabled="@_busy">Aggiorna</button>
        <button class="btn btn-primary me-2" @onclick="RetryNowAsync" disabled="@_busy">
            @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Riprova adesso
        </button>
        <button class="btn btn-outline-warning" @onclick="ReanalyzeErrorsAsync" disabled="@(_busy || _errorCount == 0)"
                title="Elimina gli advisory in errore dei run degli ultimi 7 giorni: verranno rianalizzati dal ciclo automatico.">
            Rianalizza advisory in errore
        </button>
    </div>
</div>

@if (_items is null)
{
    <p><em>Caricamento…</em></p>
}
else if (_items.Count == 0)
{
    <p><em>Nessun parere AI ancora prodotto. Compaiono qui dopo il completamento di un run del pipeline (con il layer AI abilitato).</em></p>
}
else
{
    @foreach (var item in _items)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-robot me-1"></i>Run <code>@item.RunId.ToString()[..8]</code>
                    <span class="badge @ConfidenceClass(item.Advisory.Confidence) ms-2">confidenza @item.Advisory.Confidence</span>
                    @if (item.Advisory.IsError)
                    {
                        <span class="badge bg-danger ms-1">errore</span>
                    }
                </span>
                <small class="text-muted">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm") · @item.Advisory.ModelUsed</small>
            </div>
            <div class="card-body">
                <p style="white-space: pre-wrap;">@item.Advisory.Summary</p>

                @if (item.Advisory.ParameterSuggestions.Count > 0)
                {
                    <h6 class="mt-3">Aggiustamenti proposti (da valutare, non applicati)</h6>
                    <table class="table table-sm table-striped mb-0">
                        <thead class="table-light">
                            <tr><th>Parametro</th><th>Attuale/osservato</th><th>Proposto</th><th>Motivazione</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in item.Advisory.ParameterSuggestions)
                            {
                                <tr>
                                    <td><code>@s.Parameter</code></td>
                                    <td>@s.CurrentOrObserved</td>
                                    <td><strong>@s.Suggested</strong></td>
                                    <td>@s.Rationale</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (item.Advisory.DecisionsForUser.Count > 0)
                {
                    <h6 class="mt-3">Decisioni che richiedono la tua conferma</h6>
                    <ul class="mb-0">
                        @foreach (var d in item.Advisory.DecisionsForUser)
                        {
                            <li>@d</li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
}

@code {
    private sealed record AdvisoryItem(Guid RunId, DateTime CreatedAt, SupervisorAdvisory Advisory);

    private List<AdvisoryItem>? _items;
    private LlmGuardStatus? _guard;
    private int _okCount;
    private int _errorCount;
    private int _pendingRuns;
    private bool _busy;
    private bool _actionIsError;
    private string? _actionStatus;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _busy = true;
        try
        {
            _guard = Guard.GetStatus();

            await using var db = await DbFactory.CreateDbContextAsync();
            var rows = await db.PipelineArtifacts
                .Where(a => a.Kind == LlmArtifactKinds.Advisory)
                .OrderByDescending(a => a.CreatedAt)
                .Take(50)
                .Select(a => new { a.RunId, a.CreatedAt, a.PayloadJson })
                .ToListAsync();

            _items = rows.Select(r =>
            {
                SupervisorAdvisory adv;
                try { adv = JsonSerializer.Deserialize<SupervisorAdvisory>(r.PayloadJson) ?? new(); }
                catch { adv = new SupervisorAdvisory { IsError = true, Summary = "Advisory non leggibile." }; }
                return new AdvisoryItem(r.RunId, r.CreatedAt, adv);
            }).ToList();

            _okCount = _items.Count(i => !i.Advisory.IsError);
            _errorCount = _items.Count(i => i.Advisory.IsError);

            // Stessa anti-join del worker: run completati recenti ancora senza advisory.
            var since = DateTime.UtcNow.AddDays(-7);
            _pendingRuns = await db.PipelineRuns
                .Where(r => r.Status == "Completed" && r.CompletedAt != null && r.CompletedAt >= since)
                .Where(r => !db.PipelineArtifacts.Any(a => a.RunId == r.Id && a.Kind == LlmArtifactKinds.Advisory))
                .CountAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RetryNowAsync()
    {
        _busy = true; _actionIsError = false; _actionStatus = null;
        try
        {
            await LlmWorker.TickAsync(CancellationToken.None, forceProbe: true);
            _actionStatus = "Tentativo eseguito (cooldown del breaker ignorato). Stato e advisory aggiornati qui sotto.";
        }
        catch (Exception ex)
        {
            _actionIsError = true;
            _actionStatus = $"Tentativo fallito: {ex.Message}";
        }
        finally { _busy = false; }
        await LoadAsync();
    }

    private async Task ReanalyzeErrorsAsync()
    {
        _busy = true; _actionIsError = false; _actionStatus = null;
        try
        {
            var deleted = await Supervisor.DeleteErrorAdvisoriesAsync(DateTime.UtcNow.AddDays(-7), CancellationToken.None);
            _actionStatus = deleted == 0
                ? "Nessun advisory in errore nella finestra di 7 giorni."
                : $"Eliminati {deleted} advisory in errore: i run verranno rianalizzati dal ciclo automatico (≤5 per tick), o subito con \"Riprova adesso\".";
        }
        catch (Exception ex)
        {
            _actionIsError = true;
            _actionStatus = $"Pulizia fallita: {ex.Message}";
        }
        finally { _busy = false; }
        await LoadAsync();
    }

    private static string FormatTs(DateTimeOffset? ts)
        => ts is null ? "mai" : ts.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static string ConfidenceClass(string c) => c switch
    {
        "alta" => "bg-success",
        "bassa" => "bg-secondary",
        _ => "bg-info",
    };
}
