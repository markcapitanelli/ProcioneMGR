@page "/backtest"
@rendermode InteractiveServer
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using ProcioneMGR.Data
@using ProcioneMGR.Services.Backtesting
@using ProcioneMGR.Services.Exchanges
@using ProcioneMGR.Services.Indicators
@using ProcioneMGR.Services.Optimization
@using ProcioneMGR.Services.Risk
@attribute [Authorize]

@inject IStrategyFactory StrategyFactory
@inject AuthenticationStateProvider AuthProvider
@inject BacktestPageService Svc

<PageTitle>Backtest</PageTitle>

<h1>Backtest</h1>

<GuidaPanel Title="Backtest — simula una strategia sui dati storici">
    <p>
        Un <strong>backtest</strong> risponde alla domanda "se avessi usato questa strategia di
        trading nel passato, con questi parametri, quanto avrei guadagnato o perso?". La
        piattaforma rilegge le candele storiche di un simbolo (es. Bitcoin) una a una, come se il
        tempo scorresse davvero, applica le regole della strategia scelta e simula compravendite
        con un capitale di partenza — nessun soldo reale è coinvolto, è solo una simulazione su
        dati già accaduti.
    </p>
    <dl class="row mb-0">
        <dt class="col-sm-3">Exchange / Symbol / Timeframe</dt>
        <dd class="col-sm-9">
            L'exchange (es. Binance) e la coppia da testare (es. <code>BTC/USDT</code> = quanti
            Tether servono per comprare un Bitcoin). Il <strong>timeframe</strong> è la durata di
            ogni candela (1h = una candela ogni ora): più è corto, più segnali e rumore; più è
            lungo, meno operazioni ma tendenze più pulite. Servono dati già scaricati per quel
            simbolo/timeframe — se il backtest dice "nessuna candela nel range", vai prima in
            <a href="dashboard">Dashboard</a> o <a href="market/watchlist">Watchlist</a> a scaricarli.
        </dd>
        <dt class="col-sm-3">Da / A</dt>
        <dd class="col-sm-9">Il periodo storico su cui eseguire la simulazione.</dd>
        <dt class="col-sm-3">Strategia</dt>
        <dd class="col-sm-9">
            La regola che decide quando comprare (Long), vendere allo scoperto (Short) o restare
            fuori dal mercato. Ognuna ha parametri numerici propri (es. "periodo veloce/lento" per
            una media mobile) che appaiono automaticamente quando la selezioni.
        </dd>
        <dt class="col-sm-3">Capitale iniziale</dt>
        <dd class="col-sm-9">I soldi (virtuali) con cui parte la simulazione, es. 10.000.</dd>
        <dt class="col-sm-3">Position size %</dt>
        <dd class="col-sm-9">
            Quanta parte del capitale investire a ogni operazione (es. 20% = si rischia un quinto
            del capitale per trade, non tutto in una volta).
        </dd>
        <dt class="col-sm-3">Fee %</dt>
        <dd class="col-sm-9">La commissione dell'exchange su ogni operazione (tipicamente 0.05–0.1%), sottratta dal risultato per non essere ottimisti rispetto alla realtà.</dd>
        <dt class="col-sm-3">Run Backtest / Stop</dt>
        <dd class="col-sm-9">Avvia o interrompe la simulazione (può richiedere qualche secondo su range lunghi).</dd>
        <dt class="col-sm-3">Salva come strategia</dt>
        <dd class="col-sm-9">Salva questa combinazione strategia+parametri con un nome, per ritrovarla in <a href="strategies">Le mie strategie</a> e riusarla altrove (es. nell'Ensemble).</dd>
        <dt class="col-sm-3">Final Capital / Total Return</dt>
        <dd class="col-sm-9">Il capitale alla fine della simulazione e la variazione percentuale rispetto al capitale iniziale.</dd>
        <dt class="col-sm-3">Win Rate</dt>
        <dd class="col-sm-9">Percentuale di operazioni chiuse in guadagno (non basta da sola: poche vincite grandi possono battere molte vincite piccole).</dd>
        <dt class="col-sm-3">Max Drawdown</dt>
        <dd class="col-sm-9">La peggior perdita percentuale mai subita dal punto più alto raggiunto dal capitale — indica quanto "dolore" avresti sopportato, non solo il risultato finale.</dd>
        <dt class="col-sm-3">Equity curve</dt>
        <dd class="col-sm-9">Il grafico del capitale nel tempo: sale quando si guadagna, scende quando si perde. Una linea che sale in modo regolare è preferibile a una che sale a scatti con grandi cadute.</dd>
        <dt class="col-sm-3">Trade list</dt>
        <dd class="col-sm-9">L'elenco di ogni operazione simulata: direzione (Long/Short), prezzi e orari di entrata/uscita, quantità e guadagno/perdita (PnL) in valuta e percentuale.</dd>
    </dl>
</GuidaPanel>

<div class="card mb-3">
    <div class="card-header">Configurazione</div>
    <div class="card-body">
        <ConfigPresets @ref="_presets" PageKey="backtest" UserId="@_userId" Disabled="_busy"
                       Capture="CaptureConfigJson" Apply="ApplyConfigJson"
                       AutoRestoreLast="@(Load is null && string.IsNullOrEmpty(QuerySymbol))" />
        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label">Exchange</label>
                <select class="form-select" @bind="_exchange" disabled="@_busy">
                    @foreach (var ex in Enum.GetValues<ExchangeName>())
                    {
                        <option value="@ex">@ex</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">Symbol</label>
                <input class="form-control" list="bt_symbols" @bind="_symbol" style="width: 11rem;" disabled="@_busy" />
                <datalist id="bt_symbols">
                    @foreach (var s in Svc.KnownSymbols)
                    {
                        <option value="@s"></option>
                    }
                </datalist>
            </div>
            <div class="col-auto">
                <label class="form-label">Timeframe</label>
                <select class="form-select" @bind="_timeframe" disabled="@_busy">
                    @foreach (var tf in Timeframes.Supported.Keys)
                    {
                        <option value="@tf">@tf</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">Da</label>
                <input type="date" class="form-control" @bind="_from" disabled="@_busy" />
            </div>
            <div class="col-auto">
                <label class="form-label">A</label>
                <input type="date" class="form-control" @bind="_to" disabled="@_busy" />
            </div>
        </div>

        @* Validazione preventiva: la pagina sa quali dati esistono PRIMA del Run. *@
        <DataAvailability Symbol="@_symbol" Timeframe="@_timeframe" From="_from" To="_to" Disabled="_busy"
                          OnApplyRange="@(r => { _from = r.From; _to = r.To; })"
                          OnHasDataChanged="@(has => _hasData = has)" />

        <hr />

        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label">Strategia</label>
                <select class="form-select" value="@_strategyName" @onchange="OnStrategyChanged" disabled="@_busy">
                    @foreach (var p in StrategyFactory.Prototypes)
                    {
                        <option value="@p.Name">@p.DisplayName</option>
                    }
                </select>
            </div>
            @foreach (var param in _paramInputs)
            {
                <div class="col-auto">
                    <label class="form-label">@param.Label</label>
                    <input type="number" step="any" class="form-control" style="width: 9rem;"
                           @bind="param.Value" disabled="@_busy" />
                </div>
            }
            <div class="col-auto">
                <label class="form-label">Capitale iniziale</label>
                <input type="number" step="any" class="form-control" style="width: 9rem;" @bind="_initialCapital" disabled="@_busy" />
            </div>
            <div class="col-auto">
                <label class="form-label">Position size %</label>
                <input type="number" step="any" class="form-control" style="width: 8rem;" @bind="_positionSizePercent" disabled="@_busy" />
            </div>
        </div>

        @* Fee, protezioni e attriti di mercato hanno default sensati: fuori dalla vista
           finché non servono, ma con riassunto sempre leggibile. *@
        <AdvancedPanel Summary="@AdvancedSummary">
            <div class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label">Fee %</label>
                    <input type="number" step="any" class="form-control" style="width: 7rem;" @bind="_feePercent" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Stop loss % (0=off)</label>
                    <input type="number" step="any" class="form-control" style="width: 8rem;" @bind="_stopLossPercent" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Take profit % (0=off)</label>
                    <input type="number" step="any" class="form-control" style="width: 8rem;" @bind="_takeProfitPercent" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Trailing stop % (0=off)</label>
                    <input type="number" step="any" class="form-control" style="width: 8rem;" @bind="_trailingStopPercent" disabled="@_busy" />
                </div>
                <div class="col-auto align-self-end">
                    <button type="button" class="btn btn-outline-secondary" @onclick="SuggestBracketAsync" disabled="@_busy"
                            title="Calcola SL e TP dai dati (percentili 95° di escursione avversa/favorevole) per la coppia/timeframe selezionata">
                        Suggerisci SL/TP
                    </button>
                </div>
                <div class="col-auto">
                    <label class="form-label">Leva (1=spot)</label>
                    <input type="number" step="1" min="1" max="125" class="form-control" style="width: 7rem;" @bind="_leverage" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Slippage %</label>
                    <input type="number" step="any" class="form-control" style="width: 7rem;" @bind="_slippagePercent" disabled="@_busy" />
                </div>
                <div class="col-auto">
                    <label class="form-label">Funding %/8h</label>
                    <input type="number" step="any" class="form-control" style="width: 7rem;" @bind="_fundingPercent" disabled="@_busy" />
                </div>
            </div>
        </AdvancedPanel>

        <div class="mt-3 d-flex gap-2 align-items-center">
            <button class="btn btn-primary" @onclick="RunAsync" disabled="@(_busy || NoData)"
                    title="@(NoData ? $"Nessun dato per {_symbol} {_timeframe}: scaricali prima da Watchlist." : null)">
                @if (_busy)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Run Backtest
            </button>
            @if (_busy)
            {
                <button class="btn btn-outline-danger" @onclick="Stop">Stop</button>
            }
            <button class="btn btn-outline-secondary" @onclick="SaveAsync" disabled="@_busy">Salva come strategia</button>
            <input class="form-control" style="max-width: 16rem;" placeholder="nome strategia da salvare" @bind="_saveName" disabled="@_busy" />
            <a class="btn btn-link" href="strategies">Le mie strategie →</a>
        </div>

        @if (!string.IsNullOrEmpty(_status))
        {
            <div class="alert @(_isError ? "alert-danger" : "alert-success") mt-3 mb-0">@_status</div>
        }
    </div>
</div>

@if (Svc.Result is { } result)
{
    <div class="row g-3 mb-3">
        @{
            var positive = result.TotalReturnPercent >= 0;
        }
        <div class="col-auto">@MetricCard("Final Capital", $"{result.FinalCapital:N2}")</div>
        <div class="col-auto">@MetricCard("Total Return", $"{result.TotalReturnPercent:N2}%", positive)</div>
        <div class="col-auto">@MetricCard("Win Rate", $"{result.WinRate:N1}%")</div>
        <div class="col-auto">@MetricCard("Max Drawdown", $"{result.MaxDrawdownPercent:N2}%", false)</div>
        <div class="col-auto">@MetricCard("Trades", $"{result.TotalTrades} ({result.WinningTrades}W/{result.LosingTrades}L)")</div>
        @if (result.LiquidationCount > 0)
        {
            <div class="col-auto">@MetricCard("⚠ LIQUIDAZIONI", $"{result.LiquidationCount}", false)</div>
        }
    </div>

    @* Passaggio di contesto al passo successivo del workflow: Optimization si apre
       già precompilata con simbolo, periodo, strategia e parametri di questo run. *@
    <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
        <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
            <a class="btn btn-outline-primary btn-sm" href="@BacktestPageService.OptimizationHandoffUrl(Snapshot())">
                <i class="bi bi-sliders2 me-1"></i>Ottimizza questa strategia →
            </a>
            <span class="form-text">Apre Optimization precompilata con questi simbolo, periodo e parametri.</span>
        </div>
    </AuthorizeView>

    @if (Svc.TradeReport is { OperationCount: > 0 } tradeReport)
    {
        <div class="card mb-3">
            <div class="card-header">Performance report (metriche sui trade)</div>
            <div class="card-body">
                <div class="row g-3 mb-2">
                    <div class="col-auto">@MetricCard("Net Profit", $"{tradeReport.NetProfit:N2}", tradeReport.NetProfit >= 0)</div>
                    <div class="col-auto">@MetricCard("Profit Factor", $"{tradeReport.ProfitFactor:N2}", tradeReport.ProfitFactor >= 1.5m)</div>
                    <div class="col-auto">@MetricCard("Average Trade", $"{tradeReport.AverageTrade:N2}", tradeReport.AverageTrade >= 0)</div>
                    <div class="col-auto">@MetricCard("% Win", $"{tradeReport.PercentWin:N1}%")</div>
                    <div class="col-auto">@MetricCard("Reward/Risk", $"{tradeReport.RewardRiskRatio:N2}")</div>
                    <div class="col-auto">@MetricCard("Kestner Ratio", $"{tradeReport.KestnerRatio:N2}")</div>
                </div>
                <div class="row g-3">
                    <div class="col-auto">@MetricCard("Max DD (money)", $"{tradeReport.MaxDrawdownMoney:N2}", false)</div>
                    <div class="col-auto">@MetricCard("Avg DD (money)", $"{tradeReport.AverageDrawdownMoney:N2}", false)</div>
                    <div class="col-auto">@MetricCard("Avg/Max DD", $"{tradeReport.DrawdownRatio:N2}")</div>
                    <div class="col-auto">@MetricCard("Max delay picchi", $"{tradeReport.MaxDelayBetweenPeaks}")</div>
                    <div class="col-auto">@MetricCard("Avg delay picchi", $"{tradeReport.AvgDelayBetweenPeaks:N1}")</div>
                    <div class="col-auto">@MetricCard("Max Loss", $"{tradeReport.MaxLoss:N2}", false)</div>
                    <div class="col-auto">@MetricCard("Max Win", $"{tradeReport.MaxWin:N2}", true)</div>
                </div>
                @if (Svc.Kelly is { DecidedTrades: >= 10 } kellyRes)
                {
                    <hr />
                    <p class="mb-0 small">
                        <strong>Kelly criterion</strong> (dai @kellyRes.DecidedTrades trade: p=@kellyRes.WinProbability.ToString("P1"),
                        payoff=@kellyRes.PayoffRatio.ToString("N2")): frazione ottima
                        <strong>@kellyRes.KellyFraction.ToString("P1")</strong> del capitale per trade —
                        consigliato l'half-Kelly <strong>@kellyRes.HalfKelly.ToString("P1")</strong>
                        (le stime non sono mai esatte; eccedere costa più che difettare).
                    </p>
                }
                @if (tradeReport.AnnualProfits.Count > 0)
                {
                    <hr />
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var (year, profit) in tradeReport.AnnualProfits)
                        {
                            <span class="badge @(profit >= 0 ? "bg-success" : "bg-danger")">@year: @profit.ToString("N0")</span>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Analisi del rischio (Montecarlo evoluta &amp; Performance Control)</div>
            <div class="card-body">
                <div class="row g-3 align-items-end mb-2">
                    <div class="col-auto">
                        <label class="form-label">Ricombinazioni</label>
                        <input type="number" class="form-control" style="width: 8rem;" @bind="_mcShuffles" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label">Rumore %</label>
                        <input type="number" step="any" class="form-control" style="width: 7rem;" @bind="_mcNoise" />
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-primary" @onclick="RunMonteCarlo">Montecarlo</button>
                    </div>
                    <div class="col-auto ms-4">
                        <label class="form-label">Finestra PC (trade)</label>
                        <input type="number" class="form-control" style="width: 8rem;" @bind="_pcWindow" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label">Soglia PC</label>
                        <input type="number" step="any" class="form-control" style="width: 8rem;" @bind="_pcThreshold" />
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-primary" @onclick="RunPerformanceControl">Performance Control</button>
                    </div>
                </div>

                @if (Svc.McResult is { } mcResult)
                {
                    <div class="row g-3 mb-2">
                        <div class="col-auto">@MetricCard("DD storico", $"{mcResult.OriginalMaxDrawdown:N2}", false)</div>
                        <div class="col-auto">@MetricCard("DD 95° pct", $"{mcResult.MaxDrawdown95:N2}", false)</div>
                        <div class="col-auto">@MetricCard("DD peggiore", $"{mcResult.WorstMaxDrawdown:N2}", false)</div>
                        <div class="col-auto">@MetricCard("Risk Factor 95", $"{mcResult.RiskFactor95:N2}x")</div>
                    </div>
                    <p class="text-muted small mb-2">
                        Livello di guardia consigliato: spegnere il sistema se un futuro draw down supera il
                        DD al 95° percentile (@mcResult.MaxDrawdown95.ToString("N2")), tipicamente 1.5–2.5 volte quello storico.
                    </p>
                }

                @if (Svc.LeverageAdvice is { } leverageAdvice)
                {
                    <hr />
                    <h6>Consulente leva (bootstrap sui trade di questo backtest, margine = position size)</h6>
                    @if (leverageAdvice.Warning is not null)
                    {
                        <div class="alert alert-warning py-1">@leverageAdvice.Warning</div>
                    }
                    else
                    {
                        <table class="table table-sm table-striped mb-2" style="max-width: 52rem;">
                            <thead class="table-light">
                                <tr><th>Leva</th><th class="text-end">Crescita mediana</th><th class="text-end">5° pct</th><th class="text-end">P(-50%)</th><th class="text-end">P(rovina)</th><th class="text-end">Liquidazioni</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var s in leverageAdvice.Scenarios)
                                {
                                    <tr class="@(s.Leverage == leverageAdvice.RecommendedLeverage ? "table-success" : "")">
                                        <td>@s.Leverage.ToString("N0")x</td>
                                        <td class="text-end">@s.MedianGrowth.ToString("N2")x</td>
                                        <td class="text-end">@s.Percentile5Growth.ToString("N2")x</td>
                                        <td class="text-end">@s.HalvingProbability.ToString("P0")</td>
                                        <td class="text-end">@s.RuinProbability.ToString("P0")</td>
                                        <td class="text-end">@s.LiquidationRate.ToString("P1")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <p class="text-muted small mb-0">
                            Leva massima sostenibile stimata: <strong>@leverageAdvice.RecommendedLeverage.ToString("N0")x</strong>
                            (P(-50% dal picco) ≤ 10% su @leverageAdvice.Scenarios[0].TradesPerPath trade simulati).
                            Oltre il picco di Kelly più leva significa più rischio E meno crescita mediana.
                        </p>
                    }
                }

                @if (Svc.PcResult is { } pcResult)
                {
                    <div class="row g-3">
                        <div class="col-auto">@MetricCard("Trade orig. → contr.", $"{pcResult.OriginalTradeCount} → {pcResult.ControlledTradeCount}")</div>
                        <div class="col-auto">@MetricCard("Profitto orig. → contr.", $"{pcResult.OriginalProfit:N0} → {pcResult.ControlledProfit:N0}", pcResult.ControlledProfit >= pcResult.OriginalProfit)</div>
                        @if (pcResult.OriginalProfit > 0m)
                        {
                            <div class="col-auto">@MetricCard("Profitto conservato", $"{pcResult.ProfitRetention:P0}", pcResult.ProfitRetention >= 0.8m)</div>
                        }
                        <div class="col-auto">@MetricCard("Max DD orig.", $"{pcResult.OriginalMaxDrawdown:N2}", false)</div>
                        <div class="col-auto">@MetricCard("Max DD contr.", $"{pcResult.ControlledMaxDrawdown:N2}", pcResult.MaxDrawdownRatio < 1m)</div>
                        <div class="col-auto">@MetricCard("PF orig. → contr.", $"{pcResult.OriginalReport.ProfitFactor:N2} → {pcResult.ControlledReport.ProfitFactor:N2}")</div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-header">Equity curve</div>
        <div class="card-body">
            @if (Svc.EquitySeries.Count > 0)
            {
                <OhlcvChart ShowCandles="false" Indicators="Svc.EquitySeries" Height="320" />
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">Trade list (@result.Trades.Count)</div>
        <div class="table-responsive" style="max-height: 460px; overflow:auto;">
            <table class="table table-sm table-striped mb-0">
                <thead class="table-light" style="position: sticky; top: 0;">
                    <tr>
                        <th>#</th><th>Dir</th><th>Entry</th><th>Exit</th>
                        <th class="text-end">Entry px</th><th class="text-end">Exit px</th>
                        <th class="text-end">Qty</th><th class="text-end">PnL</th><th class="text-end">PnL %</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var idx = 0;
                    }
                    @foreach (var t in result.Trades.Take(500))
                    {
                        idx++;
                        <tr>
                            <td>@idx</td>
                            <td><span class="badge @(t.Direction == "Long" ? "bg-success" : "bg-danger")">@t.Direction</span></td>
                            <td>@t.EntryTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(t.ExitTime?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                            <td class="text-end">@t.EntryPrice.ToString("N2")</td>
                            <td class="text-end">@(t.ExitPrice?.ToString("N2") ?? "—")</td>
                            <td class="text-end">@t.Quantity.ToString("N6")</td>
                            <td class="text-end @(t.Pnl >= 0 ? "text-success" : "text-danger")">@t.Pnl.ToString("N2")</td>
                            <td class="text-end @(t.PnlPercent >= 0 ? "text-success" : "text-danger")">@t.PnlPercent.ToString("N2")%</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (result.Trades.Count > 500)
        {
            <div class="card-footer text-muted">Mostrati i primi 500 di @result.Trades.Count trade.</div>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery] private int? Load { get; set; }

    // Contesto opzionale passato dall'Optimization ("Backtest →" sulle righe della Top 10):
    // precompila exchange/simbolo/periodo/strategia e i valori dei parametri.
    [SupplyParameterFromQuery(Name = "exchange")] private string? QueryExchange { get; set; }
    [SupplyParameterFromQuery(Name = "symbol")] private string? QuerySymbol { get; set; }
    [SupplyParameterFromQuery(Name = "timeframe")] private string? QueryTimeframe { get; set; }
    [SupplyParameterFromQuery(Name = "strategy")] private string? QueryStrategy { get; set; }
    [SupplyParameterFromQuery(Name = "from")] private string? QueryFrom { get; set; }
    [SupplyParameterFromQuery(Name = "to")] private string? QueryTo { get; set; }
    [SupplyParameterFromQuery(Name = "parameters")] private string? QueryParameters { get; set; }

    private ExchangeName _exchange = ExchangeName.Binance;
    private string _symbol = "BTC/USDT";
    private string _timeframe = "1h";
    private DateTime _from = DateTime.UtcNow.Date.AddDays(-30);
    private DateTime _to = DateTime.UtcNow.Date;
    private decimal _initialCapital = 10_000m;
    private decimal _positionSizePercent = 20m;
    private decimal _feePercent = 0.1m;
    private decimal _stopLossPercent;
    private decimal _takeProfitPercent;
    private decimal _trailingStopPercent;
    private decimal _leverage = 1m;
    private decimal _slippagePercent;
    private decimal _fundingPercent;

    private string _strategyName = "EmaCross";
    private List<ParamInput> _paramInputs = new();

    private int _mcShuffles = 500;
    private decimal _mcNoise;
    private int _pcWindow = 10;
    private decimal _pcThreshold;
    private string _saveName = "";
    private string? _userId;

    private bool _busy;
    private bool _isError;
    private string? _status;
    private CancellationTokenSource? _cts;

    // Aggiornato dal componente DataAvailability: false = nessuna candela per
    // symbol+timeframe correnti, quindi il Run è disabilitato con motivo visibile.
    private bool _hasData = true;

    private ConfigPresets? _presets;

    /// <summary>Fotografia corrente del form, passata al service per run/preset/handoff.</summary>
    private BacktestConfigSnapshot Snapshot() => new(
        _exchange, _symbol, _timeframe, _from, _to,
        _initialCapital, _positionSizePercent, _feePercent,
        _stopLossPercent, _takeProfitPercent, _trailingStopPercent,
        _leverage, _slippagePercent, _fundingPercent,
        _strategyName, _paramInputs.ToDictionary(p => p.Key, p => p.Value));

    /// <summary>Riallinea i campi del form a uno snapshot prodotto dal service (preset o handoff).</summary>
    private void ApplySnapshot(BacktestConfigSnapshot cfg)
    {
        _exchange = cfg.Exchange;
        _symbol = cfg.Symbol;
        _timeframe = cfg.Timeframe;
        _from = cfg.From;
        _to = cfg.To;
        _initialCapital = cfg.InitialCapital;
        _positionSizePercent = cfg.PositionSizePercent;
        _feePercent = cfg.FeePercent;
        _stopLossPercent = cfg.StopLossPercent;
        _takeProfitPercent = cfg.TakeProfitPercent;
        _trailingStopPercent = cfg.TrailingStopPercent;
        _leverage = cfg.Leverage;
        _slippagePercent = cfg.SlippagePercent;
        _fundingPercent = cfg.FundingPercent;
        _strategyName = cfg.StrategyName;
        RebuildParamInputs(cfg.Parameters);
    }

    private string CaptureConfigJson() => Svc.SerializeConfig(Snapshot());

    private void ApplyConfigJson(string json) => ApplySnapshot(Svc.ApplyConfig(json, Snapshot()));

    private bool NoData => !_hasData;

    /// <summary>Riassunto delle impostazioni avanzate, visibile a pannello chiuso.</summary>
    private string AdvancedSummary =>
        $"Fee {_feePercent:0.##}% · SL {PctOrOff(_stopLossPercent)} · TP {PctOrOff(_takeProfitPercent)}"
        + $" · Trailing {PctOrOff(_trailingStopPercent)} · Leva {_leverage:0}×"
        + $" · Slippage {_slippagePercent:0.##}% · Funding {_fundingPercent:0.##}%";

    private static string PctOrOff(decimal v) => v > 0m ? $"{v:0.##}%" : "off";

    /// <summary>
    /// Calcola SL e TP dai dati (percentili 95° di escursione) e riempie i campi del form.
    /// </summary>
    private async Task SuggestBracketAsync()
    {
        try
        {
            var res = await Svc.SuggestBracketAsync(Snapshot());
            if (!res.IsError)
            {
                _stopLossPercent = res.StopLossPercent ?? _stopLossPercent;
                _takeProfitPercent = res.TakeProfitPercent ?? _takeProfitPercent;
            }
            SetStatus(res.Message, res.IsError);
        }
        catch (Exception ex) { SetStatus($"Suggerimento SL/TP fallito: {ex.Message}", error: true); }
    }

    private sealed class ParamInput
    {
        public required string Key { get; init; }
        public required string Label { get; init; }
        public decimal Value { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier);

        // Eventuale contesto dall'Optimization (query string): valori assenti o malformati
        // lasciano i default — il link è una comodità, mai un requisito.
        var (snapshot, handoffMessage) = Svc.ApplyHandoff(
            new BacktestHandoffQuery(QueryExchange, QuerySymbol, QueryTimeframe, QueryStrategy, QueryFrom, QueryTo, QueryParameters),
            Snapshot());
        ApplySnapshot(snapshot);
        if (handoffMessage is not null) SetStatus(handoffMessage, error: false);

        await Svc.LoadKnownSymbolsAsync();

        if (Load is int id)
        {
            await LoadStrategyAsync(id);
        }
    }

    private void OnStrategyChanged(ChangeEventArgs e)
    {
        _strategyName = e.Value?.ToString() ?? "EmaCross";
        RebuildParamInputs(values: null);
    }

    /// <summary>Ricrea gli input parametro dai default della strategia corrente, con eventuale overlay di valori.</summary>
    private void RebuildParamInputs(IReadOnlyDictionary<string, decimal>? values)
    {
        _paramInputs = Svc.ParameterDefinitionsFor(_strategyName)
            .Select(d => new ParamInput
            {
                Key = d.Key,
                Label = d.Label,
                Value = values is not null && values.TryGetValue(d.Key, out var v) ? v : d.Default,
            })
            .ToList();
    }

    private async Task RunAsync()
    {
        // Memoria dell'ultima configurazione usata (best-effort, mai bloccante).
        if (_presets is not null) await _presets.SaveLastUsedAsync();

        _busy = true;
        _isError = false;
        _status = null;
        _cts = new CancellationTokenSource();

        try
        {
            var res = await Svc.RunAsync(Snapshot(), _cts.Token);
            SetStatus(res.Message, res.IsError);
        }
        catch (OperationCanceledException)
        {
            SetStatus("Backtest annullato.", error: true);
        }
        catch (Exception ex)
        {
            SetStatus($"Errore: {ex.Message}", error: true);
        }
        finally
        {
            _busy = false;
            _cts?.Dispose();
            _cts = null;
        }
    }

    private void Stop() => _cts?.Cancel();

    private void RunMonteCarlo() => Svc.RunMonteCarlo(_mcShuffles, _mcNoise);

    private void RunPerformanceControl() => Svc.RunPerformanceControl(_pcWindow, _pcThreshold);

    private async Task SaveAsync()
    {
        if (_userId is null) return;
        var res = await Svc.SaveStrategyAsync(_saveName, _strategyName, Snapshot().Parameters, _userId);
        SetStatus(res.Message, res.IsError);
        if (!res.IsError) _saveName = "";
    }

    private async Task LoadStrategyAsync(int id)
    {
        var loaded = await Svc.LoadSavedStrategyAsync(id, _userId);
        if (loaded is null) return;

        _strategyName = loaded.StrategyName;
        RebuildParamInputs(loaded.Parameters);
        SetStatus($"Caricata strategia salvata '{loaded.Name}'.", error: false);
    }

    private void SetStatus(string text, bool error)
    {
        _status = text;
        _isError = error;
    }

    // Delega al componente condiviso <Stat> (stile unico in app.css). Le call-site
    // (@MetricCard(...)) restano invariate: qui cambia solo la resa.
    private RenderFragment MetricCard(string label, string value, bool? positive = null) => builder =>
    {
        builder.OpenComponent<Stat>(0);
        builder.AddComponentParameter(1, nameof(Stat.Label), label);
        builder.AddComponentParameter(2, nameof(Stat.Value), value);
        builder.AddComponentParameter(3, nameof(Stat.Positive), positive);
        builder.CloseComponent();
    };
}
