# Configurazione NON sensibile del monolite in-cluster (Fase 3). I segreti (connection string,
# master key) stanno nel Secret ui-secrets, mai qui: questo file e' committato.
#
# E' QUI che il monolite diventa il "client puro" del PRD: con questi toggle non registra piu' alcun
# motore di trading, worker di sync o client ML in-process — delega tutto ai tre servizi via i DNS
# interni del cluster. Fuori dal cluster gli stessi toggle sono default-off
# (appsettings.json.example), quindi eseguire il monolite in locale funziona come prima.
#
# Formato: le chiavi di configurazione .NET usano ':' come separatore, ma nelle variabili d'ambiente
# si scrive '__' (doppio underscore).
#
# NB precedenza: le variabili d'ambiente vincono sull'appsettings.json (che qui e' il file condiviso
# via PVC). Nessuna di queste chiavi e' fra quelle scritte da AppConfigWriter (Trading:Safety, Llm,
# Drift, PromotionEvaluator, AutoReapply, MarketRegime, Trading:LiveExecution), quindi non c'e' il
# rischio che un pannello UI provi a cambiarle senza effetto visibile.
#
# Questo e' un file .env consumato da configMapGenerator (vedi kustomization.yaml), non un manifest:
# il ConfigMap generato ha un HASH nel nome, cosi' un cambio qui costringe davvero il pod a
# ripartire. Con un ConfigMap "nudo" le env restano quelle dell'avvio e la modifica non avrebbe
# effetto, pur risultando "Synced".

# --- Ingestion (Fase 1): il worker di sync periodico vive nel servizio remoto, non qui.
MarketData__UseRemoteIngestion=true
MarketData__RemoteIngestionUrl=http://procionemgr-ingestion.procionemgr-ingestion.svc.cluster.local:8080

# --- ML (Fase 2a): dual-read osservativo. RemoteUrl valorizzato = il client gRPC viene registrato;
# Ml__Enabled resta gestito da /admin/autonomy (hot-reload), non forzato qui.
Ml__RemoteUrl=http://procionemgr-ml.procionemgr-ml.svc.cluster.local:8080

# --- Trading (Fase 2b): il monolite NON esegue piu' ordini, li comanda via gRPC.
# ATTENZIONE: con questo a "true" il Deployment procionemgr-trading DEVE essere vivo, e viceversa
# quel Deployment non deve MAI girare con questo a "false": sarebbero due motori sullo stesso DB.
Trading__UseRemoteTrading=true
Trading__RemoteUrl=http://procionemgr-trading.procionemgr-trading.svc.cluster.local:8080

# --- Data Protection (Fase 3): percorso del keyring sul volume dedicato. Vuoto/assente fuori dal
# cluster => il default di ASP.NET Core (cartella del profilo utente), che in locale va gia' bene.
DataProtection__KeyRingPath=/keys
